Bootstrap: oras
From: ghcr.io/exabyte-io/application-containers-public/almalinux-apptainer-base:9.7-2

%labels
    Maintainer Mat3ra.com
    Version almalinux-apptainer-gnu-9.7-2

%post
    dnf install -y \
    fftw \
    fftw-devel \
    hdf5-openmpi-devel \
    lapack-devel \
    openblas \
    openblas-devel \
    openmpi \
    openmpi-devel \
    scalapack-openmpi-devel \
    rdma-core \
    ucx \
    ucx-ib \
    ucx-rdmacm

    # enable ucx, disable legacy openib
    mkdir -p /etc/openmpi
    echo "pml = ucx" >> /etc/openmpi/openmpi-mca-params.conf
    echo "btl = ^openib" >> /etc/openmpi/openmpi-mca-params.conf

    # Clean up
    dnf clean all && rm -rf /var/lib/dnf /var/cache/dnf /var/cache/yum

    cat >> $APPTAINER_ENVIRONMENT <<'EOF'
export LD_LIBRARY_PATH=/usr/lib64/openmpi/lib:$LD_LIBRARY_PATH
export PATH=/usr/lib64/openmpi/bin:$PATH

# disable legacy ucx posix link
export UCX_POSIX_USE_PROC_LINK=n

# set infiniband device when available
if [ -f /sys/class/infiniband/mlx5_0/ports/1/state ] && \
        grep -q "ACTIVE" /sys/class/infiniband/mlx5_0/ports/1/state; then
    export UCX_NET_DEVICES=mlx5_0:1
fi
EOF
